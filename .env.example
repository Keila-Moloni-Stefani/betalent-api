# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=betalent
DB_PASSWORD=betalent
DB_DATABASE=betalent

# Gateways mock (Nível 1 - sem autenticação)
GATEWAY1_URL=http://localhost:3001
GATEWAY2_URL=http://localhost:3002

# Session
SESSION_DRIVER=cookie

